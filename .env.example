APP_NAME="SIOPK Badung"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost/siopk-badung/public

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siopk_badung
DB_USERNAME=siopk_user
DB_PASSWORD=

FILESYSTEM_DISK=public
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database
APP_LOCALE=id
APP_TIMEZONE=Asia/Makassar
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ─────────────────────────────────────────────
# PRODUCTION — Override untuk deployment
# ─────────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://siopk.badungkab.go.id
# DB_HOST=mysql          ← nama service di docker-compose
# DB_PASSWORD=<password-kuat>
# SESSION_DRIVER=redis   ← gunakan Redis di production
# CACHE_STORE=redis
# REDIS_HOST=redis

# ─────────────────────────────────────────────
# AI PROVIDER — Multi-provider support
# ─────────────────────────────────────────────
# Pilih provider dengan mengisi AI_PROVIDER dan API key yang sesuai.
# Provider yang didukung: claude, openai, deepseek, groq, custom
#
#   claude   → isi CLAUDE_API_KEY
#   openai   → isi OPENAI_API_KEY
#   deepseek → isi DEEPSEEK_API_KEY (murah, daftar di https://platform.deepseek.com)
#   groq     → isi GROQ_API_KEY (gratis, daftar di https://console.groq.com)
#   custom   → isi CUSTOM_AI_* (Ollama, LM Studio, OpenRouter, dll)
#
# Hanya isi API key untuk provider yang dipilih — yang lain biarkan kosong.
# ─────────────────────────────────────────────
AI_PROVIDER=claude

# Claude (Anthropic) — https://console.anthropic.com
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MAX_TOKENS=1024
# CLAUDE_TIMEOUT=30

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_MAX_TOKENS=1024
# OPENAI_TIMEOUT=30

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_TOKENS=1024
# DEEPSEEK_TIMEOUT=30

# Groq (gratis) — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=1024
# GROQ_TIMEOUT=30

# Custom (Ollama, LM Studio, OpenRouter, dll)
# CUSTOM_AI_TYPE=openai            ← "openai" atau "claude" (format respons)
CUSTOM_AI_API_KEY=
CUSTOM_AI_API_URL=http://localhost:11434/v1/chat/completions
CUSTOM_AI_MODEL=llama3.2
# CUSTOM_AI_MAX_TOKENS=1024
# CUSTOM_AI_TIMEOUT=30

# WhatsApp Notifikasi — Fase 7 (opsional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
